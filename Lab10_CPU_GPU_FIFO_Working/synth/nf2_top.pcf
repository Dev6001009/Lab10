TIMEGRP rx_clock = TIMEGRP "clk_rx";
TIMEGRP tx_clock_gmii = TIMEGRP "clk_tx_gmii";
NET "rgmii_0_rxc_ibuf" MAXDELAY = 2.5 ns;
NET "rgmii_1_rxc_ibuf" MAXDELAY = 2.5 ns;
NET "rgmii_2_rxc_ibuf" MAXDELAY = 2.5 ns;
NET "rgmii_3_rxc_ibuf" MAXDELAY = 2.5 ns;
TS_rgmii_falling_to_rising = MAXDELAY FROM TIMEGRP "rgmii_falling" TO TIMEGRP
        "rgmii_rising" 3.2 ns;
TS_rx_clk = PERIOD TIMEGRP "rx_clock" 8 ns HIGH 50%;
TS_tx_clk_gmii = PERIOD TIMEGRP "tx_clock_gmii" 8 ns HIGH 50%;
TS_cpci_clk = PERIOD TIMEGRP "cpci_clk" 16 ns HIGH 50%;
TS_core_clk_int = PERIOD TIMEGRP "core_clk_int" 8 ns HIGH 50%;
TIMEGRP "CPCI_ADDR" OFFSET = IN 4 ns BEFORE COMP "cpci_clk";
TIMEGRP "CPCI_DATA" OFFSET = OUT 10 ns AFTER COMP "cpci_clk";
TIMEGRP "CPCI_WR_DATA" OFFSET = IN 4 ns BEFORE COMP "cpci_clk";
TIMEGRP "CPCI_RDY" OFFSET = OUT 8 ns AFTER COMP "cpci_clk";
TIMEGRP "CPCI_REQ" OFFSET = IN 4 ns BEFORE COMP "cpci_clk";
TIMEGRP "CPCI_DMA_OUT" OFFSET = OUT 8 ns AFTER COMP "cpci_clk";
TIMEGRP "CPCI_DMA_IN" OFFSET = IN 4 ns BEFORE COMP "cpci_clk";
TIMEGRP "CPCI_DMA_INOUT" OFFSET = IN 4 ns BEFORE COMP "cpci_clk";
TIMEGRP "CPCI_DMA_INOUT" OFFSET = OUT 7 ns AFTER COMP "cpci_clk";
TIMEGRP "SRAM1_OUT" OFFSET = OUT 4 ns AFTER COMP "core_clk";
TIMEGRP "SRAM1_DATA" OFFSET = IN 4 ns BEFORE COMP "core_clk";
TIMEGRP "SRAM1_DATA" OFFSET = OUT 4 ns AFTER COMP "core_clk";
TIMEGRP "SRAM2_OUT" OFFSET = OUT 4 ns AFTER COMP "core_clk";
TIMEGRP "SRAM2_DATA" OFFSET = IN 4 ns BEFORE COMP "core_clk";
TIMEGRP "SRAM2_DATA" OFFSET = OUT 4 ns AFTER COMP "core_clk";
SCHEMATIC END;

